generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum QuestionType {
  YES_NO
  MULTIPLE_CHOICE
  TEXT
  NUMBER
}

model User {
  id           String     @id @default(cuid())
  name         String     @unique
  passwordHash String
  role         Role       @default(USER)
  responses    Response[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Question {
  id        String       @id @default(cuid())
  label     String
  type      QuestionType
  options   String[]     @default([])
  unit      String?
  orderIndex Int          @default(0)
  active    Boolean      @default(true)
  responses Response[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model Response {
  id           String   @id @default(cuid())
  userId       String
  questionId   String
  answerDate   DateTime @db.Date
  valueText    String?
  valueNumber  Float?
  valueBoolean Boolean?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question     Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, questionId, answerDate])
  @@index([userId, answerDate])
}
